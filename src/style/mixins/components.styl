modal-button($thickness=15px)
  line-height normal
  padding $thickness
  label-font(weight:bold, size:$thickness)
  color #fff
  background-color teal
  border-radius(10px)
  border 0
  &:hover
    background-color darken(teal, 30%)
  &:focus-visible
    outline 2px solid focus-blue
    outline-offset 2px
    box-shadow 0 0 0 2px white
  &.default
    background-color darken(teal, 20%)
    &:hover
      background-color darken(teal, 40%)

.clickable
  cursor: pointer
