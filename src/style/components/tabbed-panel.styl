.tabbed-panel
  enable-flex(justify:flex-start, alignContent:stretch, alignItems:stretch)
  width 690px
  height: 400px
  border-radius 5px
  .workspace-tabs
    width 30%
    width dialog-tab-width
    padding 20px 0
    margin 0px
    background-color: white
    .workspace-tab
      blenderbox-modal-labels()
      font-size 14px
      -webkit-border-radius tab-border-radius
      -moz-border-radius tab-border-radius
      border-radius: tab-border-radius
      margin 10px 10px 10px 30px
      padding 10px
      color dark-gray
      background-color light-blue-2
      cursor pointer
      &.tab-selected
        -webkit-border-top-right-radius 0
        -webkit-border-bottom-right-radius 0
        -moz-border-radius-topright 0
        -moz-border-radius-bottomright 0
        border-top-right-radius 0
        border-bottom-right-radius 0
        background-color light-blue-1
        margin-right 0

  .workspace-tab-component
    position relative
    margin 3px 0
    width 70%
    border-left 3px solid light-blue-1
    padding 15px
    &[data-inert]
      display none

    .dialogTab
      position relative
      padding-bottom 50px
      input[type=text]
        width 100%
        font-size 14px
        padding 5px
        border 1px solid dark-blue
        border-radius 4px
        &:focus
          background light-blue-4
      .dialogClearFilter
        position absolute
        top 7px
        right 12px
        cursor pointer
        color #888
        background none
        border none
        padding 2px 6px
        font-size 16px
        line-height 1
        border-radius 3px
        &:hover
          color #000
          background-color #e0e0e0
      .filelist
        height 275px
        overflow auto
        margin 10px 0
        cursor pointer
        -webkit-user-select: none
        -moz-user-select: none
        -ms-user-select: none
        user-select: none;
        div
          align-items center
          display flex
          margin 2px 1px
          padding 2px
          font-size 14px
          line-height 1.3
          color: dark-gray
          i
            margin-right 7px
          .file-icon
            background url(../../img/file-new-icon.svg) no-repeat center
            background-size 24px 24px
            display inline-block
            height 24px
            margin-right 10px
            vertical-align middle
            width 24px
        div.selected
          background-color light-gray-2
        div.selectable:hover
          background-color light-gray-1
        div.selectable:active
          background-color light-gray-2
        div.subfolder
          margin-left 10px
      .provider-message
        position absolute
        bottom 0
        left 0
        right 190px /* for wrapping around buttons */
        height 50px
        display flex
        flex-direction column
        gap 5px
        justify-content center
        color #000
        font-size 14px
        .provider-message-action
          cursor pointer
          color blue
          &:hover
            text-decoration underline
      .buttons
        position absolute
        bottom 10px
        right 0
        button
          modal-button(14px)
          margin-left 10px
        button.disabled
          cursor not-allowed
          opacity .35
        a
          modal-button(14px)
          margin-right 0px
          margin-left 10px
          text-decoration none
        a.disabled
          cursor not-allowed
          opacity .35
