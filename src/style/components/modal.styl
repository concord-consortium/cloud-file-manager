dialog-width = 690px
dialog-min-height = 310px
dialog-tab-width = 247px
tab-border-radius = 5px

.modal
  position fixed
  top 0
  left 0
  width 100vw
  height 100vh
  z-index 200
  background-color rgba(119, 119, 119, 0.5)

  .modal-content
    position fixed
    top 0
    left 0
    width 100vw
    height 100vh
    z-index 201

    .modal-dialog-container
      outline none
      width 100%
      height 100%

    .modal-dialog
      absolute(0, 0, 0, 0)
      width 100%
      height 100%
      enable-flex(column, justify: center, alignItems: center)

      .modal-dialog-wrapper
        max-width dialog-width
        background-color #fff
        border-radius 4px;

        .modal-dialog-title
          align-items center
          background-color light-blue-1
          background-position 5px 5px
          background-repeat no-repeat
          background-size 24px 24px
          border-radius 4px 4px 0 0
          color dark-gray
          display flex
          label-font(weight: 500)
          line-height 1
          height 34px
          padding 10px
          text-align left

          &.dialog-import
            background-image url(../../img/file-import-icon.svg)
            padding-left 34px
          &.dialog-open
            background-image url(../../img/file-open-icon.svg)
            padding-left 34px
          &.dialog-rename
            background-image url(../../img/file-rename-icon.svg)
            padding-left 34px
          &.dialog-save
            background-image url(../../img/file-save-icon.svg)
            padding-left 34px
          &.dialog-share
            background-image url(../../img/file-shared-view-icon.svg)
            padding-left 34px

          .modal-dialog-title-close
            background url(../../img/close-modal-icon.svg) no-repeat center
            background-size 24px 24px
            border none
            cursor pointer
            height 24px
            margin 0 -5px 0 auto
            padding 0
            width 24px

        .modal-dialog-blocking-message
          border-radius 0 0 4px 4px
          padding 20px
          min-width 400px
          text-align center
          color #000

          button
            modal-button()
        
        .modal-dialog-workspace
          border-radius 0 0 4px 4px

.modal-dialog-alert
  blenderbox-modal-labels()
  font-size 12px
  color alert-orange
  margin 30px 0
  text-align center
  line-height 20px
