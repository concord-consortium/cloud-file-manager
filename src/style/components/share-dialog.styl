.share-dialog
  width 600px
  color #000

  .disabled
    opacity 0.35

  .share-top-dialog
    padding 30px

  .share-status
    margin 0 30px 30px
    font-size 22px
    text-align center

    a
      font-size 14px
      margin-left 10px

  .share-buttons
    align-items center
    display flex
    flex-direction row
    gap 20px
    justify-content center
    width 100%

    button
      modal-button()
      white-space nowrap
    .share-button-help-not-sharing
      font-size 14px
      line-height 16px
    .share-button-help-sharing
      font-size 14px
      line-height 16px

  .share-dialog-tabs-view
    padding 0 15px
    
  .sharing-tabs
    clear both
    margin 10px 5px 2px
    padding-left 10px

    li
      font-size 14px
      font-weight 500
      list-style none
      margin 0
      display inline
      border 1px solid dark-blue
      border-bottom none
      border-radius 4px 4px 0 0
      margin-right 2px
      padding 5px 10px
      cursor pointer
      &:hover
        background light-gray-2
      &:active
        background light-gray-2
      &:focus-visible
        outline 2px solid focus-blue
        outline-offset -2px
    .sharing-tab-selected
      background-color light-gray-1

  .sharing-tab-contents
    clear both
    font-size 14px
    margin 0 15px
    padding 20px
    background-color light-gray-1
    border 1px solid dark-blue
    border-radius 0 0 4px 4px

    .share-url-container
      align-items center
      display flex
      flex-direction row
      justify-content space-between

    .copy-button
      background light-blue-2
      border 1px solid dark-blue
      border-radius 4px
      color dark-gray
      font-size 14px
      font-weight bold
      padding 5px 15px
      margin-left 10px

      &:hover
        background-color light-blue-3
      &:active
        background-color light-blue-1

    .social-icons
      margin-top 10px

      .social-icon
        display: inline-block
        margin-right 7px

        width: 32px
        height: 32px
        border-radius: 50%;

        position: relative;
        overflow: hidden;
        vertical-align: middle;

        &:focus-visible
          outline none
          box-shadow 0 0 0 2px focus-blue

        .social-container
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
        .social-svg
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          fill-rule: evenodd;

        .social-svg-background,
        .social-svg-icon,
        .social-svg-mask
          transition: fill 170ms ease-in-out;
          fill: transparent;
        .social-svg-mask
          fill: #0f0b0b;

    input
      border solid 1px dark-blue
      border-radius 4px
      font-size 14px
      margin-top 10px
      margin-bottom 10px
      padding 5px
      width 100%
    input[type="checkbox"]
      width unset !important
      margin-right 5px
      margin-bottom unset
    textarea
      border 1px solid dark-blue
      border-radius 4px
      border-style inset
      margin-top 5px
      width 100%
      padding 5px
      height 75px

    .lara-settings
      margin-top 10px
      .codap-server-url
        width 68%
      .launch-button-text input
        width: 160px !important
        margin-left: 10px;
      input[type="checkbox"]
        margin-right: 10px;
        width: 10px !important

  .buttons
    clear both
    float right
    margin 20px 15px 15px

    button
      modal-button()
      margin-left 10px
    button.disabled
      background-color #777

  .longevity-warning
    margin 20px 30px